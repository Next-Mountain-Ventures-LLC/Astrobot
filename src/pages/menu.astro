                )}
                <div class="flex-1">
                  <div class="flex justify-between items-baseline gap-4 mb-2">
                    <h3 class="font-heading font-bold text-secondary text-lg">{item.name}</h3>
                    <span class="text-accent font-bold">{item.price}</span>
