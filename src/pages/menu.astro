---

<BaseLayout
  title="Menu - Limerick's Sandwich Junction"
  description="Full menu of sandwiches, salads, sides and more. 29+ signature sandwiches with 13 bread choices."
>
  <!-- HERO SECTION -->
  <section
    class="relative h-96 w-full overflow-hidden bg-cover bg-center"
    style="background-image: url('https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2Fe14e11f6d55a4a848913e080a045dbbd?format=webp&width=1600&height=900');"
  >
    <div class="absolute inset-0 bg-primary/75"></div>

    <div class="relative container flex items-center justify-center h-full">
      <div class="text-center space-y-4">
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-accent drop-shadow-lg">
          Our Menu
        </h1>
        <p class="text-lg text-background/90 drop-shadow">
          All sandwiches come with House Chips
        </p>
      </div>
    </div>
  </section>

  <!-- MENU CONTENT -->
  <section class="py-16 md:py-20 bg-background">
    <div class="container max-w-3xl">
      <!-- DELI SECTION -->
      <div class="mb-12">
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-heading text-2xl font-bold text-primary">DELI</h2>
          <div class="flex-1 h-0.5 bg-accent/40"></div>
        </div>
        <div class="space-y-6 bg-card rounded-lg p-6 border border-border/40">
          {menuItems.deli.map((item, index) => (
            <div key={index} class={index > 0 ? "border-t border-border/20 pt-4" : ""}>
              <div class="flex gap-4">
                {item.image && (
                  <img
                    src={item.image}
                    alt={item.name}
                    class="h-20 w-20 object-cover rounded flex-shrink-0 border border-border/40"
                  />
                )}
                <div class="flex-1">
                  <div class="flex justify-between items-baseline gap-4 mb-2">
                    <h3 class="font-heading font-bold text-primary text-lg">{item.name}</h3>
                    <span class="text-accent font-bold">{item.price}</span>
                  </div>
                  <p class="text-foreground/70 text-sm">{item.description}</p>
                </div>
              </div>
            </div>
          ))}
