---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { fetchInventoryFromNotion } from "@/lib/notionInventory";
import { ExternalLink, ShoppingCart, ArrowLeft } from "lucide-react";

// Fetch all inventory items at build time
const allInventory = await fetchInventoryFromNotion();

// Generate static paths for each website
export async function getStaticPaths() {
  const inventory = await fetchInventoryFromNotion();
  return inventory.map((website) => ({
    params: { slug: website.slug },
    props: { website },
  }));
}

const { website } = Astro.props;

if (!website) {
  return Astro.redirect("/websites-for-sale");
}

// Features list (generic high-quality selling points)
const features = [
  "Lightning-fast load times (75% faster than industry average)",
  "Fully mobile responsive design",
  "SEO optimized and Google-friendly",
  "Built on Astro for maximum performance",
  "Includes 1 year of premium hosting credit",
  "SSL certificate and domain setup included",
  "Customizable colors, fonts, and layouts",
  "Professional maintenance and security updates",
  "Email support and implementation help",
  "Easy to update and manage content",
];
---

<BaseLayout
  title={`${website.name} | Pre-Built Website | Astrobot.design`}
  description={website.notes || `Professional ${website.industry || 'website'} template ready to launch.`}
>
  <!-- Breadcrumb Navigation -->
  <nav class="py-4 border-b border-border/40">
    <div class="container text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/websites-for-sale" class="hover:text-foreground transition-colors">Pre-Built Websites</a>
      <span class="mx-2">/</span>
      <span class="text-foreground font-medium">{website.name}</span>
    </div>
  </nav>

  <!-- Hero Section with Website Preview -->
  <section class="relative overflow-hidden">
    {/* Full-bleed hero image */}
    <div class="relative h-96 md:h-[500px] overflow-hidden">
      <img
        src={website.thumbnailUrl}
        alt={website.name}
        class="w-full h-full object-cover"
      />
      {/* Gradient overlay */}
      <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent"></div>
    </div>

    {/* Content overlay */}
    <div class="absolute inset-0 flex flex-col justify-end pb-12 px-4">
      <div class="container">
        <div class="flex items-center gap-3 mb-4">
          <a
            href="/websites-for-sale"
            class="flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors"
          >
            <ArrowLeft class="w-4 h-4" />
            Back to Marketplace
          </a>
        </div>
        <div class="flex items-start justify-between gap-6">
          <div>
            <h1 class="text-4xl md:text-5xl font-bold mb-3">{website.name}</h1>
            {website.industry && (
              <div class="inline-block bg-primary/90 text-primary-foreground px-4 py-1 rounded-full text-sm font-medium">
                {website.industry}
              </div>
            )}
          </div>
          <div class="flex gap-3">
            {/* Preview Button */}
            <a
              href={website.websiteUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border border-foreground text-foreground hover:bg-foreground hover:text-background transition-colors font-medium"
            >
              <ExternalLink class="w-5 h-5" />
              Preview Live Site
            </a>
            
            {/* Buy Now Button */}
            {website.checkoutUrl && (
              <a
                href={website.checkoutUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-red-600 text-white hover:bg-red-700 transition-colors font-medium shadow-lg shadow-red-600/50"
              >
                <ShoppingCart class="w-5 h-5" />
                Buy Now
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Description Section -->
  {website.notes && (
    <section class="py-16 md:py-24 border-b border-border/40">
      <div class="container max-w-3xl">
        <h2 class="text-3xl font-bold mb-6">About This Website</h2>
        <p class="text-lg text-muted-foreground leading-relaxed">{website.notes}</p>
      </div>
    </section>
  )}

  <!-- Features Section -->
  <section class="py-16 md:py-24 bg-muted/30">
    <div class="container">
      <h2 class="text-3xl font-bold mb-12 text-center">What's Included</h2>
      <div class="max-w-3xl mx-auto">
        <div class="grid md:grid-cols-2 gap-6">
          {features.map((feature) => (
            <div class="flex gap-4 items-start">
              <div class="flex-shrink-0 w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center mt-1">
                <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <p class="text-muted-foreground">{feature}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Customization Section -->
  <section class="py-16 md:py-24">
    <div class="container max-w-3xl">
      <h2 class="text-3xl font-bold mb-6">Customization & Support</h2>
      <div class="space-y-6 text-muted-foreground">
        <p class="text-lg leading-relaxed">
          This pre-built website is fully customizable. We handle all setup, customization, and technical configuration.
        </p>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="p-6 bg-muted/50 rounded-lg border border-border/40">
            <h3 class="font-bold mb-3 text-foreground">What You Get</h3>
            <ul class="space-y-2 text-sm">
              <li class="flex gap-2">
                <span class="text-primary">✓</span>
                <span>Professional design template</span>
              </li>
              <li class="flex gap-2">
                <span class="text-primary">✓</span>
                <span>Content customization</span>
              </li>
              <li class="flex gap-2">
                <span class="text-primary">✓</span>
                <span>1 year of free hosting</span>
              </li>
              <li class="flex gap-2">
                <span class="text-primary">✓</span>
                <span>Technical setup & launch</span>
              </li>
            </ul>
          </div>
          <div class="p-6 bg-muted/50 rounded-lg border border-border/40">
            <h3 class="font-bold mb-3 text-foreground">Timeline</h3>
            <ul class="space-y-2 text-sm">
              <li class="flex gap-2">
                <span class="text-primary">✓</span>
                <span>3-5 days to launch</span>
              </li>
              <li class="flex gap-2">
                <span class="text-primary">✓</span>
                <span>No long design cycles</span>
              </li>
              <li class="flex gap-2">
                <span class="text-primary">✓</span>
                <span>Email support included</span>
              </li>
              <li class="flex gap-2">
                <span class="text-primary">✓</span>
                <span>Ongoing maintenance</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 bg-muted/30">
    <div class="container max-w-3xl text-center">
      <h2 class="text-3xl font-bold mb-6">Ready to Get Started?</h2>
      <p class="text-lg text-muted-foreground mb-8">
        Launch your website in 3-5 days. No long development cycles. No surprises.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        {website.checkoutUrl && (
          <a
            href={website.checkoutUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg bg-red-600 text-white hover:bg-red-700 transition-colors font-bold text-lg shadow-lg shadow-red-600/50"
          >
            <ShoppingCart class="w-6 h-6" />
            Buy Now — Get Instant Access
          </a>
        )}
        <a
          href="/websites-for-sale"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-lg border border-border hover:border-primary hover:bg-primary/5 transition-colors font-bold text-lg"
        >
          <ArrowLeft class="w-6 h-6" />
          Back to Marketplace
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
