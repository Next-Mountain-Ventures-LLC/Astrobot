---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Vegetarian Menu - Limerick's Sandwich Junction"
  description="Vegetarian sandwich options and plant-based meals at Limerick's."
>
  <!-- HERO SECTION -->
  <section class="relative h-96 w-full overflow-hidden bg-secondary">
    <div class="absolute inset-0">
      <img
        src="https://images.pexels.com/photos/1092730/pexels-photo-1092730.jpeg"
        alt="Vegetarian"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-secondary/70"></div>
    </div>

    <div class="relative container flex items-center justify-center h-full">
      <div class="text-center space-y-4">
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-accent drop-shadow-lg">
          Plant-Powered Picks
        </h1>
        <p class="text-lg text-background/90 drop-shadow">
          Delicious vegetarian options at Limerick's
        </p>
      </div>
    </div>
  </section>

  <!-- VEGETARIAN ITEMS -->
  <section class="py-16 md:py-24 bg-background">
    <div class="container max-w-3xl">
      <!-- FEATURED SANDWICHES -->
      <div class="mb-12">
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-heading text-2xl font-bold text-secondary">VEGETARIAN SANDWICHES</h2>
          <div class="flex-1 h-0.5 bg-accent/40"></div>
        </div>
        <div class="space-y-6 bg-card rounded-lg p-6 border border-border/40">
          <div>
            <div class="flex justify-between items-baseline gap-4 mb-2">
              <h3 class="font-heading font-bold text-secondary text-lg">Reita Pita</h3>
              <span class="text-accent font-bold">$12.99</span>
            </div>
            <p class="text-foreground/70 text-sm mb-3">
              Spring Mix, Hummus, Banana Peppers, Lettuce, Olive Mix, Cucumber, Feta, Chopped Tomato, Chili Oil, Garlic Toasted Hoagie
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-4 py-2 bg-secondary text-background font-bold rounded text-sm hover:bg-secondary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
          <div class="border-t border-border/20 pt-6">
            <div class="flex justify-between items-baseline gap-4 mb-2">
              <h3 class="font-heading font-bold text-secondary text-lg">Queen of Hearts</h3>
              <span class="text-accent font-bold">$12.99</span>
            </div>
            <p class="text-foreground/70 text-sm mb-3">
              Grilled Artichoke Hearts, Mushrooms, Mozzarella, Spring Mix, Banana Peppers, Sun Dried Tomato, Olive Oil, Italian Seasonings, Garlic Toasted Hoagie
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-4 py-2 bg-secondary text-background font-bold rounded text-sm hover:bg-secondary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
          <div class="border-t border-border/20 pt-6">
            <div class="flex justify-between items-baseline gap-4 mb-2">
              <h3 class="font-heading font-bold text-secondary text-lg">Dlabaj</h3>
              <span class="text-accent font-bold">$12.99</span>
            </div>
            <p class="text-foreground/70 text-sm mb-3">
              Provolone, Spring Mix, Red Onion, Balsamic Dressing, Olive Mix, Basil Mayo, Tomato, Grilled Pumpernickel
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-4 py-2 bg-secondary text-background font-bold rounded text-sm hover:bg-secondary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
        </div>
      </div>

      <!-- SALADS -->
      <div class="mb-12">
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-heading text-2xl font-bold text-primary">SALADS</h2>
          <div class="flex-1 h-0.5 bg-accent/40"></div>
        </div>
        <div class="space-y-6 bg-card rounded-lg p-6 border border-border/40">
          <div>
            <div class="flex justify-between items-baseline gap-4 mb-2">
              <h3 class="font-heading font-bold text-primary text-lg">Greek Salad</h3>
              <span class="text-accent font-bold">$11.49</span>
            </div>
            <p class="text-foreground/70 text-sm mb-3">
              Romaine, Onion, Chopped Tomato, Cucumber, Pepperoncini, Feta, Greek Olive, Pita Chips, Greek Dressing
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-4 py-2 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
          <div class="border-t border-border/20 pt-6">
            <div class="flex justify-between items-baseline gap-4 mb-2">
              <h3 class="font-heading font-bold text-primary text-lg">Field of Greens</h3>
              <span class="text-accent font-bold">$9.49</span>
            </div>
            <p class="text-foreground/70 text-sm mb-3">
              Romaine, Red Onions, Tomato, Cucumber, Dressing
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-4 py-2 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
        </div>
      </div>

      <!-- KIDS OPTIONS -->
      <div class="mb-12">
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-heading text-2xl font-bold text-secondary">KIDS VEGETARIAN</h2>
          <div class="flex-1 h-0.5 bg-accent/40"></div>
        </div>
        <div class="space-y-6 bg-card rounded-lg p-6 border border-border/40">
          <div>
            <div class="flex justify-between items-baseline gap-4 mb-2">
              <h3 class="font-heading font-bold text-secondary text-lg">Katie's Grilled Cheese</h3>
              <span class="text-accent font-bold">$5.49</span>
            </div>
            <p class="text-foreground/70 text-sm mb-3">
              Includes Chips, Kid Cookie, Kid Drink
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-4 py-2 bg-secondary text-background font-bold rounded text-sm hover:bg-secondary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
          <div class="border-t border-border/20 pt-6">
            <div class="flex justify-between items-baseline gap-4 mb-2">
              <h3 class="font-heading font-bold text-secondary text-lg">PB&J</h3>
              <span class="text-accent font-bold">$5.49</span>
            </div>
            <p class="text-foreground/70 text-sm mb-3">
              Includes Chips, Kid Cookie, Kid Drink
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block px-4 py-2 bg-secondary text-background font-bold rounded text-sm hover:bg-secondary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
        </div>
      </div>

      <!-- SIDES -->
      <div class="mb-12">
        <div class="flex items-center gap-4 mb-6">
          <h2 class="font-heading text-2xl font-bold text-primary">VEGETARIAN SIDES</h2>
          <div class="flex-1 h-0.5 bg-accent/40"></div>
        </div>
        <div class="space-y-3 bg-card rounded-lg p-6 border border-border/40">
          <div class="flex justify-between items-baseline gap-2">
            <span class="text-foreground/70">Baked Potato Salad</span>
            <span class="text-accent font-bold">$2.95</span>
          </div>
          <div class="flex justify-between items-baseline gap-2">
            <span class="text-foreground/70">Creamy Cole Slaw</span>
            <span class="text-accent font-bold">$2.95</span>
          </div>
          <div class="flex justify-between items-baseline gap-2">
            <span class="text-foreground/70">Jalapeno Cole Slaw</span>
            <span class="text-accent font-bold">$2.95</span>
          </div>
          <div class="flex justify-between items-baseline gap-2">
            <span class="text-foreground/70">Macaroni Salad</span>
            <span class="text-accent font-bold">$2.95</span>
          </div>
          <div class="flex justify-between items-baseline gap-2">
            <span class="text-foreground/70">Specialty Chips</span>
            <span class="text-accent font-bold">$2.00</span>
          </div>
          <div class="flex justify-between items-baseline gap-2">
            <span class="text-foreground/70">Pickle</span>
            <span class="text-accent font-bold">$.50</span>
          </div>
        </div>
      </div>

      <!-- BUILD YOUR OWN -->
      <div class="mb-12">
        <div class="bg-secondary/10 rounded-lg p-8 border-l-4 border-secondary">
          <h2 class="font-heading text-2xl font-bold text-secondary mb-4">
            Build Your Own Vegetarian
          </h2>
          <p class="text-foreground/80 mb-4">
            Can't find what you want? Use our <strong>Alter Ego - Build Your Own</strong> option ($13.99) and customize it as a vegetarian sandwich!
          </p>
          <p class="text-foreground/70 text-sm mb-4">
            <strong>Choose your bread:</strong> 13 different options including Marble Rye, Cuban Roll, Ciabatta, Pita, Pumpernickel, and more
          </p>
          <p class="text-foreground/70 text-sm mb-4">
            <strong>Free add-ons:</strong> Lettuce, Tomato, Onion, Pickle, Olive Mix, Hot/Mild Peppers, Condiments
          </p>
          <p class="text-foreground/70 text-sm mb-4">
            <strong>Paid extras:</strong> Avocado $.70, Cole Slaw $.50, Cheese $.70, Gluten Free Bread $1.95
          </p>
          <a
            href="/menu"
            class="inline-block px-6 py-3 bg-secondary text-background font-bold rounded hover:bg-secondary/90 transition-all duration-300"
          >
            View Full Menu
          </a>
        </div>
      </div>

      <!-- BEVERAGES & DESSERTS -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Beverages -->
        <div>
          <div class="flex items-center gap-4 mb-6">
            <h2 class="font-heading text-xl font-bold text-primary">DRINKS</h2>
            <div class="flex-1 h-0.5 bg-accent/40"></div>
          </div>
          <div class="space-y-3 bg-card rounded-lg p-6 border border-border/40">
            <div class="flex justify-between items-baseline gap-2">
              <span class="text-foreground/70">Fountain Drink</span>
              <span class="text-accent font-bold">$3.00</span>
            </div>
            <div class="flex justify-between items-baseline gap-2">
              <span class="text-foreground/70">12oz Cans</span>
              <span class="text-accent font-bold">$1.50</span>
            </div>
            <div class="flex justify-between items-baseline gap-2">
              <span class="text-foreground/70">Bottled Water</span>
              <span class="text-accent font-bold">$2.50</span>
            </div>
            <div class="flex justify-between items-baseline gap-2">
              <span class="text-foreground/70">Bottled Iced Tea</span>
              <span class="text-accent font-bold">$3.00</span>
            </div>
          </div>
        </div>

        <!-- Desserts -->
        <div>
          <div class="flex items-center gap-4 mb-6">
            <h2 class="font-heading text-xl font-bold text-primary">DESSERTS</h2>
            <div class="flex-1 h-0.5 bg-accent/40"></div>
          </div>
          <div class="space-y-3 bg-card rounded-lg p-6 border border-border/40">
            <div class="flex justify-between items-baseline gap-2">
              <span class="text-foreground/70">Reese's Peanut Butter Cookie</span>
              <span class="text-accent font-bold">$2.75</span>
            </div>
            <div class="flex justify-between items-baseline gap-2">
              <span class="text-foreground/70">Triple Chocolate Chip Cookie</span>
              <span class="text-accent font-bold">$2.75</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HIGHLIGHTS SECTION -->
  <section class="bg-accent/5 py-12">
    <div class="container max-w-3xl">
      <div class="bg-card rounded-lg p-8 border-2 border-secondary">
        <h2 class="font-heading text-2xl font-bold text-secondary mb-4">
          13 Breads to Choose From
        </h2>
        <p class="text-foreground/80 mb-4">
          Every vegetarian sandwich at Limerick's can be made on your choice of 13 different fresh breads:
        </p>
        <div class="grid grid-cols-2 gap-2 text-sm text-foreground/70 mb-4">
          <div>• Marble Rye</div>
          <div>• Pumpernickel</div>
          <div>• Cuban Roll</div>
          <div>• Ciabatta</div>
          <div>• Hoagie</div>
          <div>• Telera Roll</div>
          <div>• Multigrain</div>
          <div>• Wheatberry</div>
          <div>• Pita</div>
          <div>• Texas Toast</div>
          <div>• Brioche</div>
          <div>• Baguette</div>
          <div>• Onion Roll</div>
        </div>
        <p class="text-foreground/70 text-sm">
          Mix and match with our fresh, hand-crafted vegetarian options to create the perfect meal!
        </p>
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="bg-secondary py-12">
    <div class="container text-center space-y-4">
      <h2 class="font-heading text-3xl font-bold text-accent">Plant-Based. Flavorful. Fresh.</h2>
      <p class="text-background/90 text-lg max-w-xl mx-auto">
        All our vegetarian options are made to order with fresh, locally sourced ingredients
      </p>
      <a
        href="https://limerickssandwichjunction.smartonlineorder.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-8 py-4 bg-accent text-secondary font-bold rounded hover:bg-accent/90 transition-all duration-300 text-lg"
      >
        Order Now
      </a>
    </div>
  </section>
</BaseLayout>
