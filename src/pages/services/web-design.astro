---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TestimonialCard from "@/components/services/TestimonialCard.astro";
---

<BaseLayout
  title="Web Design for Small Businesses | Astrobot.design"
  description="Custom websites built for small business growth. Fast, SEO-optimized, and designed for conversions."
>
  <!-- Breadcrumb Navigation -->
  <nav class="py-4 border-b border-border/40">
    <div class="container text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/services/web-design" class="text-foreground font-medium">Web Design</a>
    </div>
  </nav>

  <section class="py-20 md:py-32">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl md:text-5xl font-bold mb-6 text-foreground">
            Custom Websites Built for Small Business Growth
          </h1>
          <p class="text-xl text-muted-foreground mb-8">
            Professional web design that gets results. 75% faster than traditional sites, optimized for search engines, and built to convert visitors into customers.
          </p>
          <div class="flex gap-4">
            <a href="https://buy.stripe.com/5kQbJ2dec6ZIc7L0HKgMw01" target="_blank" rel="noopener noreferrer" class="bg-primary text-primary-foreground px-8 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors inline-flex items-center gap-2">
              Book Your Consultation
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
            </a>
            <a href="#how-it-works" class="border border-border px-8 py-3 rounded-lg font-medium hover:bg-muted transition-colors">
              See How It Works
            </a>
          </div>
        </div>
        <div class="bg-gradient-to-br from-primary/10 to-primary/5 rounded-lg h-96 flex items-center justify-center">
          <p class="text-muted-foreground">Professional Design Showcase</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-32 bg-muted/30">
    <div class="container">
      <h2 class="text-3xl font-bold mb-12 text-center">Why Small Businesses Choose Astrobot</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="p-6 bg-background rounded-lg border border-border hover:border-primary/50 transition-colors">
          <h3 class="font-bold text-lg mb-3">⚡ 75% Faster Loading</h3>
          <p class="text-muted-foreground">Built with Astro framework for blazing-fast performance. Better search rankings, happier visitors.</p>
        </div>
        <div class="p-6 bg-background rounded-lg border border-border hover:border-primary/50 transition-colors">
          <h3 class="font-bold text-lg mb-3">🔍 SEO-Optimized</h3>
          <p class="text-muted-foreground">Every site is built with search engines in mind. Structured data, fast load times, and best practices included.</p>
        </div>
        <div class="p-6 bg-background rounded-lg border border-border hover:border-primary/50 transition-colors">
          <h3 class="font-bold text-lg mb-3">🤖 AI + Human Design</h3>
          <p class="text-muted-foreground">Leveraging AI intelligence with human creativity. Strategic design that aligns with your business goals.</p>
        </div>
        <div class="p-6 bg-background rounded-lg border border-border hover:border-primary/50 transition-colors">
          <h3 class="font-bold text-lg mb-3">✨ Zero Bloat</h3>
          <p class="text-muted-foreground">No unnecessary code or plugins. Clean, minimal, and maintainable architecture.</p>
        </div>
        <div class="p-6 bg-background rounded-lg border border-border hover:border-primary/50 transition-colors">
          <h3 class="font-bold text-lg mb-3">🚀 Launch in 1 Week</h3>
          <p class="text-muted-foreground">Quick turnaround from strategy to launch. Get online faster without sacrificing quality.</p>
        </div>
        <div class="p-6 bg-background rounded-lg border border-border hover:border-primary/50 transition-colors">
          <h3 class="font-bold text-lg mb-3">🛠️ Maintenance-Free</h3>
          <p class="text-muted-foreground">Hosted and maintained for you. Focus on your business while we keep your site running smoothly.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="how-it-works" class="py-20 md:py-32">
    <div class="container">
      <h2 class="text-3xl font-bold mb-12 text-center">Our Simple 3-Step Process</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-primary">1</span>
          </div>
          <h3 class="font-bold text-lg mb-3">Strategy</h3>
          <p class="text-muted-foreground">
            We understand your business, goals, and target audience. A personalized strategy guides the entire project.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-primary">2</span>
          </div>
          <h3 class="font-bold text-lg mb-3">Design & Build</h3>
          <p class="text-muted-foreground">
            Our designers create a beautiful, functional website optimized for conversions and search engines.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-primary">3</span>
          </div>
          <h3 class="font-bold text-lg mb-3">Launch & Grow</h3>
          <p class="text-muted-foreground">
            Your site goes live. We handle hosting and maintenance while you focus on growing your business.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-32 bg-muted/30">
    <div class="container">
      <h2 class="text-3xl font-bold mb-12 text-center">What Our Clients Say</h2>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <TestimonialCard
          quote="Astrobot delivered our website in just one week. It's incredibly fast and our search rankings improved immediately. Best investment we've made."
          author="Sarah Chen"
          title="Owner"
          company="Chen & Co. Consulting"
        />
        <TestimonialCard
          quote="The combination of AI insights and human creativity resulted in a website that truly represents our brand. Our conversion rate increased by 45%."
          author="Michael Rodriguez"
          title="Marketing Director"
          company="Rodriguez Digital Services"
        />
      </div>
    </div>
  </section>

  <section class="py-20 md:py-32">
    <div class="container">
      <h2 class="text-3xl font-bold mb-12 text-center">Pricing & Options</h2>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="p-8 bg-background rounded-lg border border-border hover:shadow-lg transition-shadow">
          <h3 class="font-bold text-2xl mb-2">Orbit</h3>
          <p class="text-muted-foreground mb-4">Perfect for startups</p>
          <p class="text-3xl font-bold mb-6">$1,500</p>
          <ul class="space-y-3 mb-6">
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">5 custom pages</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">Mobile responsive</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">SEO optimized</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">1-week launch</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">1 year hosting included</span>
            </li>
          </ul>
          <a href="https://buy.stripe.com/5kQbJ2dec6ZIc7L0HKgMw01" target="_blank" rel="noopener noreferrer" class="w-full block bg-primary text-primary-foreground py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors text-center">
            Get Started
          </a>
        </div>
        <div class="p-8 bg-background rounded-lg border border-2 border-primary">
          <div class="inline-block bg-primary text-primary-foreground px-3 py-1 rounded-full text-sm font-medium mb-4">
            Most Popular
          </div>
          <h3 class="font-bold text-2xl mb-2">Supernova</h3>
          <p class="text-muted-foreground mb-4">For established businesses</p>
          <p class="text-3xl font-bold mb-6">$3,500</p>
          <ul class="space-y-3 mb-6">
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">Unlimited pages</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">Blog integration</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">Advanced SEO</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">3-week launch</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">1 year hosting + ongoing support</span>
            </li>
          </ul>
          <a href="https://buy.stripe.com/5kQbJ2dec6ZIc7L0HKgMw01" target="_blank" rel="noopener noreferrer" class="w-full block bg-primary text-primary-foreground py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors text-center">
            Get Started
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-32 bg-muted/30">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold mb-6">Not Sure Which Plan Is Right?</h2>
        <p class="text-lg text-muted-foreground mb-8">
          Let's talk about your project. Book a free consultation with our design team.
        </p>
        <a href="https://buy.stripe.com/5kQbJ2dec6ZIc7L0HKgMw01" target="_blank" rel="noopener noreferrer" class="inline-block bg-primary text-primary-foreground px-8 py-4 rounded-lg font-medium hover:bg-primary/90 transition-colors text-lg">
          Book Your Free Consultation
        </a>
        <p class="text-sm text-muted-foreground mt-6">
          Or explore <a href="/websites-for-sale" class="text-primary hover:text-primary/80">pre-built websites for faster launch</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
