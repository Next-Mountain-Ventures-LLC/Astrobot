---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from '@/components/home/Hero';
import RecentlyLaunchedWebsitesCarousel from '@/components/home/RecentlyLaunchedWebsitesCarousel';
import Newsletter from '@/components/home/Newsletter';
import BlogPreview from '@/components/home/BlogPreview.astro';
import CTA from '@/components/home/CTA';
import { fetchPortfolioFromNotion } from '@/lib/notionPortfolio';

// Fetch portfolio data at build time from Notion
console.log('[Page] Starting portfolio fetch from Notion...');
const portfolioItems = await fetchPortfolioFromNotion();
console.log('[Page] Portfolio items fetched:', portfolioItems.length);
console.log('[Page] Using', portfolioItems.length > 0 ? 'LIVE Notion data' : 'FALLBACK data');

// Fallback data if Notion fetch fails
const fallbackData = [
  {
    title: "Climb.Coach",
    url: "https://www.climb.coach",
    thumbnailUrl: "https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2F0f528ff509c94641a1f08e1fd81084f9?format=webp&width=800&height=1200",
    info: "Business Coaching",
    industry: "Coaching"
  },
  {
    title: "Ennis Slingshot",
    url: "https://www.ennisslingshot.com",
    thumbnailUrl: "https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2F0f528ff509c94641a1f08e1fd81084f9?format=webp&width=800&height=1200",
    info: "Sports Equipment",
    industry: "Sports"
  },
  {
    title: "Ecclesia Tulsa",
    url: "https://www.ecclesiatulsa.com",
    thumbnailUrl: "https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2F0f528ff509c94641a1f08e1fd81084f9?format=webp&width=800&height=1200",
    info: "Church Community",
    industry: "Religious"
  },
  {
    title: "Search SERPA",
    url: "https://www.searchserpa.com",
    thumbnailUrl: "https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2F99c1338e912341a2a302a0c82103339f?format=webp&width=800&height=1200",
    info: "SEO Services",
    industry: "SEO"
  }
];

// Use fetched data if available, otherwise use fallback
const websites = portfolioItems.length > 0 ? portfolioItems : fallbackData;
---

<BaseLayout
  title="Blazing Fast Websites, Dedicated Designer"
  description="AI-powered, human-designed websites that load up to 75% faster than traditional sites. Book your designer today."
>
  <!-- Hero Section (critical) -->
  <Hero client:load />

  <!-- Recently Launched Websites Section -->
  <RecentlyLaunchedWebsitesCarousel client:load websites={websites} />

  <!-- Blog Preview Section -->
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="mb-12">
        <h2 class="text-3xl font-bold mb-3">Latest from the Blog</h2>
        <p class="text-muted-foreground max-w-xl">
          Learn about web design, speed optimization, SEO, and how to grow your business online.
        </p>
      </div>
      <BlogPreview />
      <div class="text-center mt-12">
        <a href="/blog" class="inline-block border border-border px-6 py-3 rounded-lg font-medium hover:bg-muted transition-colors">
          Read All Articles
        </a>
      </div>
    </div>
  </section>

  <!-- Newsletter Section -->
  <Newsletter client:idle />

  <!-- CTA Section -->
  <CTA client:idle />
</BaseLayout>
