---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { FlipCard } from "@/components/FlipCard";
import { ReviewCarousel } from "@/components/ReviewCarousel";

const reviews = [
  {
    id: "1",
    text: "Stopped here to meet some family who live locally for lunch and was recommended by others. Yummy little sandwich shop right smack in little downtown... I ordered the Reuben and lovedddd it! The potato salad was creamy and appeasing, and the jalapeño coleslaw definite had a kick of spice to it yet still enjoyable. The sandwiches are quite large so my mom and grandma shared one and filled up. I will absolutely return when I'm back in the area!",
    author: "Stevie K.",
    location: "Austin, TX",
    date: "Nov 25, 2025",
    platform: "yelp" as const,
    rating: 5,
    profileImage: "https://s3-media1.fl.yelpcdn.com/photo/QjeddcR_LqxICOnHZNnPwA/ms.jpg"
  },
  {
    id: "2",
    text: "The Italian Sandwich is delish! I want to go back here everyday for lunch, and I would if I worked closer. Limerick's Sandwich Junction is right off the main street through downtown Ennis. Really clean dining room with lots of seating. Staff was working hard to get sandwiches out quick. I also had the macaroni salad with my sandwich and it was delish as well.",
    author: "Lana Y.",
    location: "Waxahachie, TX",
    date: "Sep 27, 2024",
    platform: "yelp" as const,
    rating: 5,
    profileImage: "https://s3-media1.fl.yelpcdn.com/photo/n1l0GL1p_24OprI4p00QTg/ms.jpg"
  },
  {
    id: "3",
    text: "Amazing sandwiches and the service is second to none. Loved it and the staff were awesome creating such an amazing atmosphere.",
    author: "Tj T.",
    location: "Richardson, TX",
    date: "Nov 19, 2025",
    platform: "yelp" as const,
    rating: 5,
    profileImage: "https://s3-media1.fl.yelpcdn.com/photo/xMEoe3Nrf3wrfezkog6UJg/ms.jpg"
  },
  {
    id: "4",
    text: "Great food, friendly staff and fast service. A little pricey but you get what you pay for and the food is great.",
    author: "Ronald H.",
    location: "Tucson, AZ",
    date: "Nov 10, 2025",
    platform: "yelp" as const,
    rating: 5,
    profileImage: "https://s3-media1.fl.yelpcdn.com/photo/0YsxMlv_HXDmn9REtF5Azw/ms.jpg"
  },
  {
    id: "5",
    text: "Both sandwiches were delivered fresh and loaded with meat and veggies. The Weinberger Reuben was very tasty. The Dagwood was the best!! I got it exactly the way it came, and it has to be one of the best sandwiches I've had!!! Will definitely be a return customer!!!",
    author: "Tina N.",
    location: "Ennis, TX",
    date: "Nov 27, 2024",
    platform: "yelp" as const,
    rating: 5,
    profileImage: "https://s3-media1.fl.yelpcdn.com/photo/8BGyLaOoE1iRYwAVog-Sig/ms.jpg"
  },
  {
    id: "6",
    text: "Had the best sandwich I have had in a long time today. Possibly ever. I ordered the 'Heaton' after a recommendation. The fresh ingredients, texture and flavor combinations all balanced perfectly and for just a sandwich, it was remarkable. Give it a try.",
    author: "Hunter R.",
    location: "Piedra, CO",
    date: "Jul 8, 2025",
    platform: "yelp" as const,
    rating: 5,
    profileImage: "https://s3-media0.fl.yelpcdn.com/assets/srv0/yelp_styleguide/514f6997a318/assets/img/default_avatars/user_60_square.png"
  },
  {
    id: "7",
    text: "If ever in Ennis, don't miss this cute little shop! We stopped in for a late lunch while driving down from Dallas. The sandwich ingredients were fresh and very tasty, and the servings were large. One of the best Turkey sandwiches I've had.",
    author: "Kim B.",
    location: "Oklahoma City, OK",
    date: "Apr 16, 2023",
    platform: "yelp" as const,
    rating: 5,
    profileImage: "https://s3-media1.fl.yelpcdn.com/photo/Eu9BFFW94EQkSAwH39EIXw/ms.jpg"
  },
  {
    id: "8",
    text: "The Weinberger Rueben Sandwich was as amazing as everyone said. A big sandwich that had a perfect blend of flavors. Can't wait to try more of the delicious looking sandwiches on the menu.",
    author: "Russell W.",
    location: "Carrollton, TX",
    date: "May 15, 2024",
    platform: "yelp" as const,
    rating: 5,
    profileImage: "https://s3-media1.fl.yelpcdn.com/photo/gj4v5AuUyT1RFR_PRXvr-w/ms.jpg"
  },
  {
    id: "9",
    text: "Hollingshayes cubano is AMAZING, two huge halves (already ate one) and you have to get the baked potato salad, super fresh and flavorful. Love the deli vibes and artwork.",
    author: "Jena M.",
    location: "Providence, RI",
    date: "May 13, 2024",
    platform: "yelp" as const,
    rating: 5,
    profileImage: "https://s3-media1.fl.yelpcdn.com/photo/zVpQhRXEqLE-JIEUKLWq2g/ms.jpg"
  },
  {
    id: "10",
    text: "Best sandwiches ever — mic drop — seriously don't go to Subway, no comparison whatsoever. My go-to sandwich there is the Weinberg Ruben. They're the best.",
    author: "Randall T.",
    location: "Duncanville, TX",
    date: "Aug 27, 2024",
    platform: "yelp" as const,
    rating: 5,
    profileImage: "https://s3-media1.fl.yelpcdn.com/photo/6lqvHD3VzgJv2RnGSnoi2Q/ms.jpg"
  }
];

const whyCards = [
  {
    title: "Hand-Crafted Daily",
    description: "Every sandwich is made fresh to order with premium ingredients and attention to detail.",
    icon: "🥪"
  },
  {
    title: "29+ Signature Sandwiches",
    description: "From classic Reubens and Italian subs to New Orleans specials and Cuban presses. Something for everyone.",
    icon: "📋"
  },
  {
    title: "13 Bread Choices",
    description: "Marble Rye, Cuban, Ciabatta, Pumpernickel, and more. Choose your perfect base.",
    icon: "🍞"
  },
  {
    title: "Family Owned & Operated",
    description: "Proudly serving Downtown Ennis with passion, pride, and a commitment to quality that shows in every bite.",
    icon: "❤️"
  }
];
---

<BaseLayout
  title="Limerick's Sandwich Junction - Best Sandwiches in Downtown Ennis, TX"
  description="Award-winning sandwich restaurant in downtown Ennis, TX. Hand-crafted sandwiches, 13 bread choices, locally sourced ingredients."
>
  <!-- HERO SECTION -->
  <section class="relative h-[500px] md:h-[600px] w-full overflow-hidden">
    <!-- Video Background -->
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover"
      poster="https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2Fa1d0cc579f044ca7960283ccecfa02a9?format=webp&width=1600&height=900"
    >
      <source src="https://videos.files.wordpress.com/cHScOtA2/website.mp4" type="video/mp4" />
    </video>

    <!-- Content -->
    <div class="relative container flex items-center justify-center h-full">
      <div class="text-center space-y-6 max-w-2xl mx-auto">
        <h1 class="font-heading text-4xl md:text-6xl font-bold text-accent" style="text-shadow: 0 2px 8px rgba(0,0,0,0.8), 0 4px 16px rgba(0,0,0,0.7), 0 0 30px rgba(0,0,0,0.6);">
          Best Sandwiches in Town
        </h1>
        <p class="text-lg md:text-xl text-background/90" style="text-shadow: 0 2px 6px rgba(0,0,0,0.8), 0 3px 12px rgba(0,0,0,0.7);">
          Locally sourced. Hand-crafted. Served with heart in Downtown Ennis, TX.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
          <a
            href="/menu"
            class="inline-flex px-8 py-4 bg-accent text-primary font-bold rounded hover:bg-accent/90 transition-all duration-300 text-lg"
          >
            View Our Menu
          </a>
          <a
            href="https://limerickssandwichjunction.smartonlineorder.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex px-8 py-4 bg-background text-primary font-bold rounded hover:bg-background/90 transition-all duration-300 text-lg"
          >
            Order Online Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF & REVIEWS SECTION -->
  <section class="py-20 md:py-28 bg-gradient-to-b from-background via-accent/5 to-background">
    <div class="container">
      <!-- Header -->
      <div class="text-center mb-16">
        <h2 class="font-heading text-4xl md:text-5xl font-bold text-primary mb-4">
          What Our Customers Say
        </h2>
        <p class="text-lg text-foreground/70 max-w-2xl mx-auto">
          Tasted by over <span class="font-bold text-accent">900 satisfied customers</span> across Yelp, Google, and DoorDash
        </p>
      </div>

      <!-- Review Carousel -->
      <ReviewCarousel client:load reviews={reviews} />
    </div>
  </section>

  <!-- FAN FAVORITES -->
  <section class="py-12 md:py-16 bg-accent/5">
    <div class="container">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-8">
        Fan Favorites
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Weinberger Reuben -->
        <div class="bg-card rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-border/40">
          <div class="h-48 overflow-hidden bg-gray-200" style="background-image: url('https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2F855e66657c29464eb6f722e40ac9ad91?format=webp&width=800&height=1200'); background-size: cover; background-position: center;">
            <img
              src="https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2F855e66657c29464eb6f722e40ac9ad91?format=webp&width=800&height=1200"
              alt="Weinberger Reuben"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-4 space-y-3">
            <div class="flex justify-between items-start">
              <h3 class="font-heading font-bold text-primary text-lg">Weinberger Reuben</h3>
              <span class="text-accent font-bold">$14.49</span>
            </div>
            <p class="text-sm text-foreground/70 leading-relaxed">
              Hot Corned Beef & Pastrami, Swiss, Sauerkraut, Russian Dressing, Grilled Marble Rye
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block w-full text-center px-3 py-2 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
        </div>

        <!-- The Dagwood -->
        <div class="bg-card rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-border/40">
          <div class="h-48 overflow-hidden bg-gray-200" style="background-image: url('https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2Fda8bd39873fb42ea905695a4d889b342?format=webp&width=800&height=1200'); background-size: cover; background-position: center;">
            <img
              src="https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2Fda8bd39873fb42ea905695a4d889b342?format=webp&width=800&height=1200"
              alt="The Dagwood"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-4 space-y-3">
            <div class="flex justify-between items-start">
              <h3 class="font-heading font-bold text-primary text-lg">The Dagwood</h3>
              <span class="text-accent font-bold">$13.99</span>
            </div>
            <p class="text-sm text-foreground/70 leading-relaxed">
              Ham, Turkey, Roast Beef, Swiss, Muenster, American Cheese, Mayo, Tomato
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block w-full text-center px-3 py-2 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
        </div>

        <!-- Muffuletta -->
        <div class="bg-card rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-border/40">
          <div class="h-48 overflow-hidden bg-gray-200" style="background-image: url('https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2F1eeb7d4c628842ffad1d558a1a0f21b6?format=webp&width=800&height=1200'); background-size: cover; background-position: center;">
            <img
              src="https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2F1eeb7d4c628842ffad1d558a1a0f21b6?format=webp&width=800&height=1200"
              alt="Muffuletta"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-4 space-y-3">
            <div class="flex justify-between items-start">
              <h3 class="font-heading font-bold text-primary text-lg">Muffuletta</h3>
              <span class="text-accent font-bold">$17.00</span>
            </div>
            <p class="text-sm text-foreground/70 leading-relaxed">
              Mortadella, Genoa Salami, Capicola, Provolone, Swiss, Olive Mix, Olive Oil
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block w-full text-center px-3 py-2 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
        </div>

        <!-- Hollingshayes Cubano -->
        <div class="bg-card rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-border/40">
          <div class="h-48 overflow-hidden bg-gray-200" style="background-image: url('https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2F7701a299eddc4812aa246298b44de0aa?format=webp&width=800&height=1200'); background-size: cover; background-position: center;">
            <img
              src="https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2F7701a299eddc4812aa246298b44de0aa?format=webp&width=800&height=1200"
              alt="Hollingshayes Cubano"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-4 space-y-3">
            <div class="flex justify-between items-start">
              <h3 class="font-heading font-bold text-primary text-lg">Hollingshayes Cubano</h3>
              <span class="text-accent font-bold">$13.99</span>
            </div>
            <p class="text-sm text-foreground/70 leading-relaxed">
              Grilled Roast Pork, Ham, Yellow Mustard, Kosher Dill, Provolone
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block w-full text-center px-3 py-2 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY LIMERICK'S -->
  <section class="py-12 md:py-16 bg-background">
    <div class="container">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-8">
        Why Limerick's
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {whyCards.map((card) => (
          <div class="bg-card rounded-lg p-6 border border-border/40 hover:shadow-lg transition-shadow duration-300">
            <h3 class="font-heading font-bold text-primary text-lg mb-3">{card.title}</h3>
            <p class="text-foreground/70 text-sm leading-relaxed">{card.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COME FIND US SECTION -->
  <section class="py-12 md:py-16 bg-accent/5">
    <div class="container">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-8">
        Come Find Us
      </h2>

      <!-- Main Grid: Left Info, Right Video/Map -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:items-start">
        <!-- Left: Hours and Address -->
        <div class="flex flex-col space-y-4 h-full">
          <!-- Hours Table -->
          <div class="bg-card rounded-lg p-6 border border-border/40">
            <h3 class="font-heading font-bold text-primary text-lg mb-4">Hours</h3>
            <table class="w-full text-sm">
              <tbody>
                <tr class="border-b border-border/20">
                  <td class="py-2 text-foreground/70 font-medium">Monday</td>
                  <td class="py-2 text-right text-foreground font-bold">11:00 AM - 5:00 PM</td>
                </tr>
                <tr class="border-b border-border/20">
                  <td class="py-2 text-foreground/70 font-medium">Tuesday</td>
                  <td class="py-2 text-right text-foreground font-bold">11:00 AM - 5:00 PM</td>
                </tr>
                <tr class="border-b border-border/20">
                  <td class="py-2 text-foreground/70 font-medium">Wednesday</td>
                  <td class="py-2 text-right text-foreground font-bold">11:00 AM - 5:00 PM</td>
                </tr>
                <tr class="border-b border-border/20">
                  <td class="py-2 text-foreground/70 font-medium">Thursday</td>
                  <td class="py-2 text-right text-foreground font-bold">11:00 AM - 5:00 PM</td>
                </tr>
                <tr class="border-b border-border/20">
                  <td class="py-2 text-foreground/70 font-medium">Friday</td>
                  <td class="py-2 text-right text-foreground font-bold">11:00 AM - 5:00 PM</td>
                </tr>
                <tr class="border-b border-border/20">
                  <td class="py-2 text-foreground/70 font-medium">Saturday</td>
                  <td class="py-2 text-right text-foreground font-bold">11:00 AM - 5:00 PM</td>
                </tr>
                <tr>
                  <td class="py-2 text-foreground/70 font-medium">Sunday</td>
                  <td class="py-2 text-right text-foreground font-bold">Closed</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Address and Phone -->
          <div class="bg-card rounded-lg p-6 border border-border/40 space-y-3">
            <div>
              <h4 class="font-heading font-bold text-primary text-sm mb-1">Address</h4>
              <p class="text-foreground/80 text-sm leading-relaxed">
                213 W. Ennis Avenue, Ste 100<br />
                Downtown Ennis, TX 75119
              </p>
            </div>
            <div>
              <h4 class="font-heading font-bold text-primary text-sm mb-1">Phone</h4>
              <a href="tel:+19034051995" class="text-primary hover:text-primary/80 font-bold transition-colors text-sm">
                (903) 405-1995
              </a>
            </div>
          </div>

          <!-- CTA -->
          <a
            href="https://limerickssandwichjunction.smartonlineorder.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-auto block w-full text-center px-8 py-4 bg-primary text-accent font-bold rounded text-lg hover:bg-primary/90 transition-all duration-300"
          >
            Order Online Now
          </a>
        </div>

        <!-- Right: Video and Map Stacked -->
        <div class="space-y-4">
          <!-- Location Video -->
          <div class="rounded-lg overflow-hidden shadow-lg border-4 border-accent/30 h-64">
            <video
              autoplay
              muted
              loop
              playsinline
              class="w-full h-full object-cover"
            >
              <source src="https://videos.files.wordpress.com/yFdLsfGs/location-website.mov" type="video/mp4" />
            </video>
          </div>

          <!-- Map -->
          <div class="bg-gray-200 rounded-lg overflow-hidden h-64 border-4 border-accent/30">
            <iframe
              width="100%"
              height="100%"
              frameborder="0"
              style="border:0"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3331.5559815887246!2d-96.6127456!3d32.3254!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x864c1d5a5e5e5e5d%3A0x1e5e5e5e5e5e5!2s213%20W%20Ennis%20Ave%20%23100%2C%20Ennis%2C%20TX%2075119!5e0!3m2!1sen!2sus!4v1234567890"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>

          <!-- Navigation Button -->
          <div class="flex gap-3">
            <a
              href="https://maps.apple.com/?address=213%20W.%20Ennis%20Avenue,%20Ste%20100,%20Ennis,%20TX%2075119&dirflg=d"
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 text-center px-4 py-3 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Apple Maps
            </a>
            <a
              href="https://www.google.com/maps/dir/?api=1&destination=213+W+Ennis+Avenue+Ste+100+Ennis+TX+75119"
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 text-center px-4 py-3 bg-accent text-primary font-bold rounded text-sm hover:bg-accent/90 transition-all duration-300"
            >
              Google Maps
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
