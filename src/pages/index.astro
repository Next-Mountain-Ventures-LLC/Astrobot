---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Limerick's Sandwich Junction - Best Sandwiches in Downtown Ennis, TX"
  description="Award-winning sandwich restaurant in downtown Ennis, TX. Hand-crafted sandwiches, 13 bread choices, locally sourced ingredients."
>
  <!-- HERO SECTION -->
  <section class="relative h-[500px] md:h-[600px] w-full overflow-hidden">
    <!-- Video Background -->
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute inset-0 w-full h-full object-cover"
    >
      <source src="https://videos.files.wordpress.com/cHScOtA2/website.mp4" type="video/mp4" />
    </video>

    <!-- Content -->
    <div class="relative container flex items-center justify-center h-full">
      <div class="text-center space-y-6 max-w-2xl mx-auto">
        <h1 class="font-heading text-4xl md:text-6xl font-bold text-accent" style="text-shadow: 0 2px 8px rgba(0,0,0,0.8), 0 4px 16px rgba(0,0,0,0.7), 0 0 30px rgba(0,0,0,0.6);">
          Best Sandwiches in Town
        </h1>
        <p class="text-lg md:text-xl text-background/90" style="text-shadow: 0 2px 6px rgba(0,0,0,0.8), 0 3px 12px rgba(0,0,0,0.7);">
          Locally sourced. Hand-crafted. Served with heart in Downtown Ennis, TX.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center pt-4">
          <a
            href="/menu"
            class="inline-flex px-8 py-4 bg-accent text-primary font-bold rounded hover:bg-accent/90 transition-all duration-300 text-lg"
          >
            View Our Menu
          </a>
          <a
            href="https://limerickssandwichjunction.smartonlineorder.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex px-8 py-4 bg-background text-primary font-bold rounded hover:bg-background/90 transition-all duration-300 text-lg"
          >
            Order Online Now
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- RATINGS STRIP -->
  <section class="bg-accent/10 border-y-4 border-accent/30 py-12">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Yelp Card -->
        <div class="flex items-center gap-4 bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
          <img
            src="https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2Fddc8d91775f349cdb2d5832d37b936bf?format=webp&width=100&height=40"
            alt="Yelp"
            class="h-10 w-auto flex-shrink-0"
            loading="lazy"
          />
          <div class="flex-1">
            <div class="text-3xl font-bold text-accent leading-tight">4.7★</div>
            <p class="text-sm text-foreground/70 font-medium leading-snug">87 reviews</p>
          </div>
        </div>

        <!-- DoorDash Card -->
        <div class="flex items-center gap-4 bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
          <img
            src="https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2Fbd030c0b510348e78181e8e68e34686c?format=webp&width=120&height=40"
            alt="DoorDash"
            class="h-10 w-auto flex-shrink-0"
            loading="lazy"
          />
          <div class="flex-1">
            <div class="text-3xl font-bold text-accent leading-tight">4.8★</div>
            <p class="text-sm text-foreground/70 font-medium leading-snug">500+ reviews</p>
          </div>
        </div>

        <!-- Google Card -->
        <div class="flex items-center gap-4 bg-white rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
          <img
            src="https://cdn.builder.io/api/v1/image/assets%2F5193f7a05d654f0c98a0a70f48ef2387%2F8d66a665163641a1876ffac7dab6fec2?format=webp&width=100&height=40"
            alt="Google"
            class="h-10 w-auto flex-shrink-0"
            loading="lazy"
          />
          <div class="flex-1">
            <div class="text-3xl font-bold text-accent leading-tight">4.8★</div>
            <p class="text-sm text-foreground/70 font-medium leading-snug">269 reviews</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY LIMERICK'S -->
  <section class="py-16 md:py-24 bg-background">
    <div class="container">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-16">
        Why Limerick's
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Card 1 -->
        <div class="flex flex-col group">
          <div class="relative h-1 w-12 bg-accent mb-6 group-hover:w-full transition-all duration-300"></div>
          <h3 class="font-heading text-xl font-bold text-primary mb-3">Hand-Crafted Daily</h3>
          <p class="text-foreground/70 leading-relaxed flex-1">Every sandwich is made fresh to order with premium ingredients and attention to detail.</p>
        </div>

        <!-- Card 2 -->
        <div class="flex flex-col group">
          <div class="relative h-1 w-12 bg-accent mb-6 group-hover:w-full transition-all duration-300"></div>
          <h3 class="font-heading text-xl font-bold text-primary mb-3">29+ Signature Sandwiches</h3>
          <p class="text-foreground/70 leading-relaxed flex-1">From classic Reubens and Italian subs to New Orleans specials and Cuban presses. Something for everyone.</p>
        </div>

        <!-- Card 3 -->
        <div class="flex flex-col group">
          <div class="relative h-1 w-12 bg-accent mb-6 group-hover:w-full transition-all duration-300"></div>
          <h3 class="font-heading text-xl font-bold text-primary mb-3">13 Bread Choices</h3>
          <p class="text-foreground/70 leading-relaxed flex-1">Marble Rye, Cuban, Ciabatta, Pumpernickel, and more. Choose your perfect base.</p>
        </div>

        <!-- Card 4 -->
        <div class="flex flex-col group">
          <div class="relative h-1 w-12 bg-accent mb-6 group-hover:w-full transition-all duration-300"></div>
          <h3 class="font-heading text-xl font-bold text-primary mb-3">Family Owned & Operated</h3>
          <p class="text-foreground/70 leading-relaxed flex-1">Proudly serving Downtown Ennis with passion, pride, and a commitment to quality that shows in every bite.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAN FAVORITES -->
  <section class="py-16 md:py-24 bg-accent/5">
    <div class="container">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-12">
        Fan Favorites
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Weinberger Reuben -->
        <div class="bg-card rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-border/40">
          <div class="h-48 overflow-hidden bg-gray-200" style="background-image: url('https://images.pexels.com/photos/1633578/pexels-photo-1633578.jpeg?auto=compress&cs=tinysrgb&w=800'); background-size: cover; background-position: center;">
            <img
              src="https://images.pexels.com/photos/1633578/pexels-photo-1633578.jpeg?auto=compress&cs=tinysrgb&w=800"
              alt="Weinberger Reuben"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-4 space-y-3">
            <div class="flex justify-between items-start">
              <h3 class="font-heading font-bold text-primary text-lg">Weinberger Reuben</h3>
              <span class="text-accent font-bold">$14.49</span>
            </div>
            <p class="text-sm text-foreground/70 leading-relaxed">
              Hot Corned Beef & Pastrami, Swiss, Sauerkraut, Russian Dressing, Grilled Marble Rye
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block w-full text-center px-3 py-2 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
        </div>

        <!-- The Dagwood -->
        <div class="bg-card rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-border/40">
          <div class="h-48 overflow-hidden bg-gray-200" style="background-image: url('https://images.pexels.com/photos/2955819/pexels-photo-2955819.jpeg?auto=compress&cs=tinysrgb&w=800'); background-size: cover; background-position: center;">
            <img
              src="https://images.pexels.com/photos/2955819/pexels-photo-2955819.jpeg?auto=compress&cs=tinysrgb&w=800"
              alt="The Dagwood"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-4 space-y-3">
            <div class="flex justify-between items-start">
              <h3 class="font-heading font-bold text-primary text-lg">The Dagwood</h3>
              <span class="text-accent font-bold">$13.99</span>
            </div>
            <p class="text-sm text-foreground/70 leading-relaxed">
              Ham, Turkey, Roast Beef, Swiss, Muenster, American Cheese, Mayo, Tomato
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block w-full text-center px-3 py-2 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
        </div>

        <!-- Muffuletta -->
        <div class="bg-card rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-border/40">
          <div class="h-48 overflow-hidden bg-gray-200" style="background-image: url('https://images.pexels.com/photos/1647164/pexels-photo-1647164.jpeg?auto=compress&cs=tinysrgb&w=800'); background-size: cover; background-position: center;">
            <img
              src="https://images.pexels.com/photos/1647164/pexels-photo-1647164.jpeg?auto=compress&cs=tinysrgb&w=800"
              alt="Muffuletta"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-4 space-y-3">
            <div class="flex justify-between items-start">
              <h3 class="font-heading font-bold text-primary text-lg">Muffuletta</h3>
              <span class="text-accent font-bold">$17.00</span>
            </div>
            <p class="text-sm text-foreground/70 leading-relaxed">
              Mortadella, Genoa Salami, Capicola, Provolone, Swiss, Olive Mix, Olive Oil
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block w-full text-center px-3 py-2 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
        </div>

        <!-- Hollingshayes Cubano -->
        <div class="bg-card rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-border/40">
          <div class="h-48 overflow-hidden bg-gray-200" style="background-image: url('https://images.pexels.com/photos/1647163/pexels-photo-1647163.jpeg?auto=compress&cs=tinysrgb&w=800'); background-size: cover; background-position: center;">
            <img
              src="https://images.pexels.com/photos/1647163/pexels-photo-1647163.jpeg?auto=compress&cs=tinysrgb&w=800"
              alt="Hollingshayes Cubano"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
              loading="lazy"
            />
          </div>
          <div class="p-4 space-y-3">
            <div class="flex justify-between items-start">
              <h3 class="font-heading font-bold text-primary text-lg">Hollingshayes Cubano</h3>
              <span class="text-accent font-bold">$13.99</span>
            </div>
            <p class="text-sm text-foreground/70 leading-relaxed">
              Grilled Roast Pork, Ham, Yellow Mustard, Kosher Dill, Provolone
            </p>
            <a
              href="https://limerickssandwichjunction.smartonlineorder.com/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block w-full text-center px-3 py-2 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Order
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS SECTION -->
  <section class="py-16 md:py-24 bg-background">
    <div class="container">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-12">
        What Our Customers Say
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-card rounded-lg p-6 border-l-4 border-accent shadow-md">
          <div class="flex items-center gap-1 mb-3">
            {[1, 2, 3, 4, 5].map(() => (
              <span class="text-accent text-lg">★</span>
            ))}
          </div>
          <p class="text-foreground/80 italic mb-4">
            "I want to go back here every day for lunch... The Italian Sandwich is delish!"
          </p>
          <p class="text-sm font-bold text-primary">Lana Y.</p>
          <p class="text-xs text-foreground/60">Yelp Elite, Waxahachie TX</p>
        </div>

        <div class="bg-card rounded-lg p-6 border-l-4 border-accent shadow-md">
          <div class="flex items-center gap-1 mb-3">
            {[1, 2, 3, 4, 5].map(() => (
              <span class="text-accent text-lg">★</span>
            ))}
          </div>
          <p class="text-foreground/80 italic mb-4">
            "The Weinberger Reuben was as amazing as everyone said. A big sandwich with a perfect blend of flavors."
          </p>
          <p class="text-sm font-bold text-primary">Russell W.</p>
          <p class="text-xs text-foreground/60">Verified Reviewer</p>
        </div>

        <div class="bg-card rounded-lg p-6 border-l-4 border-accent shadow-md">
          <div class="flex items-center gap-1 mb-3">
            {[1, 2, 3, 4, 5].map(() => (
              <span class="text-accent text-lg">★</span>
            ))}
          </div>
          <p class="text-foreground/80 italic mb-4">
            "Hollingshayes cubano is AMAZING... get the baked potato salad, super fresh and flavorful. Love the deli vibes!"
          </p>
          <p class="text-sm font-bold text-primary">Yelp Reviewer</p>
          <p class="text-xs text-foreground/60">Ennis, TX</p>
        </div>
      </div>
    </div>
  </section>

  <!-- COME FIND US SECTION -->
  <section class="py-16 md:py-24 bg-accent/5">
    <div class="container">
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-primary text-center mb-12">
        Come Find Us
      </h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:items-start">
        <!-- Left: Info and Hours -->
        <div class="space-y-8" style="max-height: fit-content;">
          <!-- Hours Table -->
          <div class="bg-card rounded-lg p-6 border border-border/40">
            <h3 class="font-heading font-bold text-primary text-lg mb-4">Hours</h3>
            <table class="w-full text-sm">
              <tbody>
                <tr class="border-b border-border/20">
                  <td class="py-2 text-foreground/70 font-medium">Monday - Saturday</td>
                  <td class="py-2 text-right text-foreground font-bold">11:00 AM - 5:00 PM</td>
                </tr>
                <tr>
                  <td class="py-2 text-foreground/70 font-medium">Sunday</td>
                  <td class="py-2 text-right text-foreground font-bold">Closed</td>
                </tr>
              </tbody>
            </table>
          </div>

          <!-- Address and Phone -->
          <div class="bg-card rounded-lg p-6 border border-border/40 space-y-4">
            <div>
              <h4 class="font-heading font-bold text-primary text-sm mb-2">Address</h4>
              <p class="text-foreground/80 leading-relaxed">
                213 W. Ennis Avenue, Ste 100<br />
                Downtown Ennis, TX 75119
              </p>
            </div>
            <div>
              <h4 class="font-heading font-bold text-primary text-sm mb-2">Phone</h4>
              <a href="tel:+19034051995" class="text-primary hover:text-primary/80 font-bold transition-colors">
                (903) 405-1995
              </a>
            </div>
          </div>

          <!-- CTA -->
          <a
            href="https://limerickssandwichjunction.smartonlineorder.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full text-center px-8 py-4 bg-primary text-accent font-bold rounded text-lg hover:bg-primary/90 transition-all duration-300"
          >
            Order Online Now
          </a>
        </div>

        <!-- Right: Map -->
        <div class="bg-gray-200 rounded-lg overflow-hidden h-[500px] md:h-[700px] border-4 border-accent/30 sticky top-32">
          <iframe
            width="100%"
            height="100%"
            frameborder="0"
            style="border:0"
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3331.5559815887246!2d-96.6127456!3d32.3254!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x864c1d5a5e5e5e5d%3A0x1e5e5e5e5e5e5e5!2s213%20W%20Ennis%20Ave%20%23100%2C%20Ennis%2C%20TX%2075119!5e0!3m2!1sen!2sus!4v1234567890"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
