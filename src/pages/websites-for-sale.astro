---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TestimonialCard from "@/components/services/TestimonialCard.astro";
---

<BaseLayout
  title="Professional Websites for Sale | Ready to Launch | Astrobot.design"
  description="Pre-built, professionally designed websites ready to launch. No custom design needed. Get online in days, not weeks."
>
  <!-- Breadcrumb Navigation -->
  <nav class="py-4 border-b border-border/40">
    <div class="container text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/websites-for-sale" class="text-foreground font-medium">Websites for Sale</a>
    </div>
  </nav>
  <section class="py-20 md:py-32">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h1 class="text-4xl md:text-5xl font-bold mb-6 text-foreground">
            Professional Websites for Sale
          </h1>
          <p class="text-xl text-muted-foreground mb-8">
            Ready-made, professionally designed websites. No months of planning. No design back-and-forths. Just launch and start selling.
          </p>
          <div class="flex gap-4">
            <a href="#gallery" class="bg-primary text-primary-foreground px-8 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors inline-flex items-center gap-2">
              Browse Websites
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
            </a>
            <a href="/services/web-design" class="border border-border px-8 py-3 rounded-lg font-medium hover:bg-muted transition-colors">
              Want Custom Design?
            </a>
          </div>
        </div>
        <div class="bg-gradient-to-br from-primary/10 to-primary/5 rounded-lg h-96 flex items-center justify-center">
          <p class="text-muted-foreground">Website showcase</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-32 bg-muted/30">
    <div class="container">
      <h2 class="text-3xl font-bold mb-12 text-center">The Problem & Your Solution</h2>
      <div class="grid md:grid-cols-2 gap-12 max-w-4xl mx-auto">
        <div>
          <h3 class="font-bold text-xl mb-4 text-red-500">❌ Custom Design</h3>
          <ul class="space-y-2 text-muted-foreground">
            <li>• 2-3 months to launch</li>
            <li>• $3,000+ investment</li>
            <li>• Multiple rounds of revisions</li>
            <li>• Unclear timeline</li>
            <li>• Design from scratch</li>
          </ul>
        </div>
        <div>
          <h3 class="font-bold text-xl mb-4 text-primary">✓ Pre-Built Solution</h3>
          <ul class="space-y-2 text-muted-foreground">
            <li>• Launch in 3-5 days</li>
            <li>• $500-1,500 total</li>
            <li>• Customize immediately</li>
            <li>• Guaranteed timeline</li>
            <li>• Proven design</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-32">
    <div class="container">
      <h2 class="text-3xl font-bold mb-12 text-center">How It Works</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-primary">1</span>
          </div>
          <h3 class="font-bold text-lg mb-3">Browse</h3>
          <p class="text-muted-foreground">
            Explore our gallery of professional websites. Find a design that matches your industry and vision.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-primary">2</span>
          </div>
          <h3 class="font-bold text-lg mb-3">Customize</h3>
          <p class="text-muted-foreground">
            Add your content, colors, and branding. We handle all the technical setup and customization.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-primary">3</span>
          </div>
          <h3 class="font-bold text-lg mb-3">Launch</h3>
          <p class="text-muted-foreground">
            Your website is live and ready to attract customers. We handle hosting and maintenance.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-32 bg-muted/30">
    <div class="container">
      <h2 class="text-3xl font-bold mb-12 text-center">What's Included</h2>
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="p-6 bg-background rounded-lg border border-border">
          <h3 class="font-bold text-lg mb-4">Design & Performance</h3>
          <ul class="space-y-3">
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">Professional design template</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">Mobile responsive</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">75% faster load times</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">SEO pre-optimized</span>
            </li>
          </ul>
        </div>
        <div class="p-6 bg-background rounded-lg border border-border">
          <h3 class="font-bold text-lg mb-4">Support & Hosting</h3>
          <ul class="space-y-3">
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">Free hosting (1 year)</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">SSL certificate included</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">Maintenance & updates</span>
            </li>
            <li class="flex gap-2">
              <span class="text-primary">✓</span>
              <span class="text-muted-foreground">Email support</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="gallery" class="py-20 md:py-32">
    <div class="container">
      <h2 class="text-3xl font-bold mb-12 text-center">Available Websites</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="rounded-lg overflow-hidden border border-border hover:shadow-lg transition-shadow">
          <div class="bg-gradient-to-br from-blue-500/20 to-blue-500/5 h-48 flex items-center justify-center">
            <p class="text-muted-foreground">Professional Services Template</p>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-lg mb-2">Professional Services</h3>
            <p class="text-muted-foreground text-sm mb-4">Perfect for consultants, agencies, and service providers.</p>
            <p class="font-bold text-lg mb-4">$799</p>
            <a href="https://buy.stripe.com/5kQbJ2dec6ZIc7L0HKgMw01" target="_blank" rel="noopener noreferrer" class="w-full block border border-border px-4 py-2 rounded-lg hover:bg-primary/10 hover:border-primary transition-colors text-center font-medium">
              Purchase Now
            </a>
          </div>
        </div>

        <div class="rounded-lg overflow-hidden border border-border hover:shadow-lg transition-shadow">
          <div class="bg-gradient-to-br from-green-500/20 to-green-500/5 h-48 flex items-center justify-center">
            <p class="text-muted-foreground">E-Commerce Template</p>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-lg mb-2">E-Commerce Store</h3>
            <p class="text-muted-foreground text-sm mb-4">Start selling online with a professional storefront.</p>
            <p class="font-bold text-lg mb-4">$1,299</p>
            <a href="https://buy.stripe.com/5kQbJ2dec6ZIc7L0HKgMw01" target="_blank" rel="noopener noreferrer" class="w-full block border border-border px-4 py-2 rounded-lg hover:bg-primary/10 hover:border-primary transition-colors text-center font-medium">
              Purchase Now
            </a>
          </div>
        </div>

        <div class="rounded-lg overflow-hidden border border-border hover:shadow-lg transition-shadow">
          <div class="bg-gradient-to-br from-purple-500/20 to-purple-500/5 h-48 flex items-center justify-center">
            <p class="text-muted-foreground">Portfolio Template</p>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-lg mb-2">Creative Portfolio</h3>
            <p class="text-muted-foreground text-sm mb-4">Showcase your work and attract clients.</p>
            <p class="font-bold text-lg mb-4">$599</p>
            <a href="https://buy.stripe.com/5kQbJ2dec6ZIc7L0HKgMw01" target="_blank" rel="noopener noreferrer" class="w-full block border border-border px-4 py-2 rounded-lg hover:bg-primary/10 hover:border-primary transition-colors text-center font-medium">
              Purchase Now
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-32 bg-muted/30">
    <div class="container">
      <h2 class="text-3xl font-bold mb-12 text-center">Frequently Asked Questions</h2>
      <div class="max-w-2xl mx-auto space-y-4">
        <details class="border border-border rounded-lg p-6">
          <summary class="font-bold cursor-pointer">Can I customize the design after purchase?</summary>
          <p class="text-muted-foreground mt-4">Absolutely. We handle all customization including colors, fonts, content, and layout. You can also request additional features.</p>
        </details>
        <details class="border border-border rounded-lg p-6">
          <summary class="font-bold cursor-pointer">Can I add a blog later?</summary>
          <p class="text-muted-foreground mt-4">Yes! All our websites support blog functionality. We can add it at any time for an additional fee.</p>
        </details>
        <details class="border border-border rounded-lg p-6">
          <summary class="font-bold cursor-pointer">Do I own the website?</summary>
          <p class="text-muted-foreground mt-4">Yes, you own your website and all content. You can move it anytime. We provide the hosting and maintenance during your subscription.</p>
        </details>
        <details class="border border-border rounded-lg p-6">
          <summary class="font-bold cursor-pointer">How long does setup take?</summary>
          <p class="text-muted-foreground mt-4">Most setups are complete within 3-5 days. This includes customization, content setup, and final testing.</p>
        </details>
        <details class="border border-border rounded-lg p-6">
          <summary class="font-bold cursor-pointer">What happens after the first year of hosting?</summary>
          <p class="text-muted-foreground mt-4">Hosting renews at $99/year, or you can transfer to another host. Your website remains yours to keep.</p>
        </details>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-32">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold mb-6">Ready to Launch?</h2>
        <p class="text-lg text-muted-foreground mb-8">
          Pick your template and go live in days. No long development cycles. No surprises.
        </p>
        <a href="#gallery" class="inline-block bg-primary text-primary-foreground px-8 py-4 rounded-lg font-medium hover:bg-primary/90 transition-colors text-lg">
          Browse Websites
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
