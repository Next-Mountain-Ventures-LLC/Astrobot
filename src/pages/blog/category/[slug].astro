---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogCard from "@/components/blog/BlogCard.astro";
import { getPosts } from "@/lib/wordpress";

// Fetch all posts to determine available categories
const allPosts = await getPosts(1, 100);

// Get unique category slugs from all posts
const uniqueCategories = new Set<string>();
allPosts.forEach(post => {
  post.categories.forEach(cat => {
    uniqueCategories.add(cat.slug);
  });
});

// Define category metadata
const categoryMetadata: Record<string, { name: string; description: string }> = {
  "web-design": {
    name: "Web Design",
    description: "Responsive design, UX, design trends, and CSS tips for modern websites."
  },
  "web-speed": {
    name: "Web Speed",
    description: "Page speed optimization, core web vitals, lighthouse scores, and performance best practices."
  },
  "seo-technical": {
    name: "Technical SEO",
    description: "Technical SEO, on-page optimization, schema markup, and indexing strategies."
  },
  "websites-for-sale": {
    name: "Websites for Sale",
    description: "Pre-built websites, templates, quick launches, and ready-made solutions."
  },
  "case-studies": {
    name: "Case Studies",
    description: "Real client success stories, before/after results, and project breakdowns."
  },
  "news-trends": {
    name: "News & Trends",
    description: "Web development trends, industry updates, and emerging technologies."
  }
};

export async function getStaticPaths() {
  // Fetch all posts
  const posts = await getPosts(1, 100);
  
  // Get unique category slugs
  const categories = new Set<string>();
  posts.forEach(post => {
    post.categories.forEach(cat => {
      categories.add(cat.slug);
    });
  });
  
  // Generate paths for each category
  return Array.from(categories).map(slug => ({
    params: { slug }
  }));
}

const { slug } = Astro.params;

// Filter posts by the current category slug
const categoryPosts = allPosts.filter(post => 
  post.categories.some(cat => cat.slug === slug)
);

// Get metadata for the current category
const metadata = categoryMetadata[slug] || {
  name: slug.split('-').map(s => s.charAt(0).toUpperCase() + s.slice(1)).join(' '),
  description: `Articles about ${slug.replace(/-/g, ' ')}`
};

// Get other categories for related links
const otherCategories = Array.from(uniqueCategories)
  .filter(cat => cat !== slug)
  .slice(0, 3)
  .map(cat => ({
    slug: cat,
    ...categoryMetadata[cat]
  }));
---

<BaseLayout
  title={`${metadata.name} | Blog | Astrobot.design`}
  description={metadata.description}
>
  <section class="py-16 md:py-24">
    <div class="container">
      <div class="max-w-3xl mx-auto mb-12">
        <nav class="mb-6">
          <a href="/blog" class="text-muted-foreground hover:text-foreground transition-colors">
            ← Back to Blog
          </a>
        </nav>
        
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          {metadata.name}
        </h1>
        <p class="text-xl text-muted-foreground">
          {metadata.description}
        </p>
      </div>

      {categoryPosts.length === 0 ? (
        <div class="text-center py-12 border border-primary/10 rounded-lg bg-secondary/20">
          <p class="text-lg text-muted-foreground">No articles found in this category yet.</p>
          <a href="/blog" class="inline-block mt-4 text-primary hover:text-primary/80 transition-colors">
            Browse all articles →
          </a>
        </div>
      ) : (
        <>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
            {categoryPosts.map(post => (
              <BlogCard post={post} />
            ))}
          </div>

          {otherCategories.length > 0 && (
            <section class="mt-20 pt-16 border-t border-border">
              <h2 class="text-2xl font-bold mb-8">Explore Other Categories</h2>
              <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {otherCategories.map((cat) => (
                  <a 
                    href={`/blog/category/${cat.slug}`}
                    class="p-6 bg-muted/30 rounded-lg border border-border hover:border-primary hover:bg-muted/50 transition-all group"
                  >
                    <h3 class="font-bold text-lg mb-2 group-hover:text-primary transition-colors">
                      {cat.name}
                    </h3>
                    <p class="text-sm text-muted-foreground">
                      {cat.description}
                    </p>
                  </a>
                ))}
              </div>
            </section>
          )}
        </>
      )}
    </div>
  </section>

  <section class="py-16 md:py-24 bg-muted/30">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-4">Subscribe to Our Newsletter</h2>
        <p class="text-muted-foreground mb-8">
          Get insights about web design, speed optimization, and growing your business online.
        </p>
        <form class="flex gap-2 max-w-md mx-auto">
          <input 
            type="email" 
            placeholder="Enter your email"
            class="flex-1 px-4 py-3 rounded-lg border border-border bg-background placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            required
          />
          <button 
            type="submit"
            class="bg-primary text-primary-foreground px-6 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
