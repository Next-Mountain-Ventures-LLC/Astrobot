---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogCard from "@/components/blog/BlogCard.astro";
import { getCategoriesWithNames, getCategoryDisplayName, getPostsByCategory, getAllCategories } from "@/lib/blog-utils";

// Get all categories dynamically from WordPress
// This ensures new categories automatically appear as tabs
const allCategories = await getAllCategories();
const categoriesWithNames = await getCategoriesWithNames();

export async function getStaticPaths() {
  // Generate a page for each category found in WordPress posts
  const categories = await getAllCategories();
  
  return categories.map(slug => ({
    params: { slug }
  }));
}

const { slug } = Astro.params;

// Get posts for this specific category
const categoryPosts = await getPostsByCategory(slug);

// Get display name for this category
const categoryDisplayName = getCategoryDisplayName(slug);
---

<BaseLayout
  title={`${categoryDisplayName} | Blog | Astrobot.design`}
  description={`Browse blog posts in the ${categoryDisplayName} category.`}
>
  <!-- Breadcrumb Navigation -->
  <nav class="py-4 border-b border-border/40">
    <div class="container text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/blog" class="hover:text-foreground transition-colors">Blog</a>
      <span class="mx-2">/</span>
      <span class="text-foreground font-medium">{categoryDisplayName}</span>
    </div>
  </nav>

  <section class="py-16 md:py-24">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-heading font-bold tracking-tight mb-6">
          Our Blog
        </h1>
        <p class="text-xl text-muted-foreground mb-8">
          Insights and tips for building faster, better websites
        </p>

        <!-- Category Navigation Tabs -->
        <!-- These automatically update whenever new categories are added to WordPress -->
        <!-- Selected category highlighted with primary color -->
        <div class="flex flex-wrap gap-2 justify-center mb-8">
          <a href="/blog" class="px-4 py-2 rounded-full bg-muted text-muted-foreground text-sm font-medium hover:bg-muted/80 hover:text-foreground transition-colors">
            All Posts
          </a>
          {categoriesWithNames.map(({ slug: catSlug, displayName }) => (
            <a
              href={`/blog/category/${catSlug}`}
              class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${
                catSlug === slug 
                  ? 'bg-primary text-primary-foreground hover:bg-primary/90' 
                  : 'bg-muted text-muted-foreground hover:bg-muted/80 hover:text-foreground'
              }`}
            >
              {displayName}
            </a>
          ))}
        </div>
      </div>

      {categoryPosts.length === 0 ? (
        <div class="text-center py-12 border border-primary/10 rounded-lg bg-secondary/20">
          <p class="text-lg text-muted-foreground">No articles found in this category yet.</p>
          <a href="/blog" class="inline-block mt-4 text-primary hover:text-primary/80 transition-colors">
            Browse all articles →
          </a>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {categoryPosts.map(post => (
            <BlogCard post={post} />
          ))}
        </div>
      )}
    </div>
  </section>

  <section class="py-16 md:py-24 bg-muted/30">
    <div class="container">
      <div class="max-w-2xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-4">Subscribe to Our Newsletter</h2>
        <p class="text-muted-foreground mb-8">
          Get insights about web design, speed optimization, and growing your business online.
        </p>
        <form class="flex gap-2 max-w-md mx-auto">
          <input 
            type="email" 
            placeholder="Enter your email"
            class="flex-1 px-4 py-3 rounded-lg border border-border bg-background placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary"
            required
          />
          <button 
            type="submit"
            class="bg-primary text-primary-foreground px-6 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
