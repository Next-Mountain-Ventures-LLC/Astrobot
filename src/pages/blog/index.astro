---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Blog - Limerick's Sandwich Junction"
  description="Stories, specials, and sandwich love from downtown Ennis."
>
  <!-- HERO SECTION -->
  <section class="relative h-96 w-full overflow-hidden bg-secondary">
    <div class="absolute inset-0">
      <img
        src="https://images.pexels.com/photos/546069/pexels-photo-546069.jpeg"
        alt="Blog"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-secondary/70"></div>
    </div>

    <div class="relative container flex items-center justify-center h-full">
      <div class="text-center space-y-4">
        <h1 class="font-heading text-4xl md:text-5xl font-bold text-accent drop-shadow-lg">
          From the Junction
        </h1>
        <p class="text-lg text-background/90 drop-shadow">
          Stories, specials, and sandwich love from downtown Ennis
        </p>
      </div>
    </div>
  </section>

  <!-- BLOG POSTS GRID -->
  <section class="py-16 md:py-24 bg-background">
    <div class="container max-w-4xl">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Blog Post 1 -->
        <article class="bg-card rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-border/40">
          <div class="h-48 overflow-hidden bg-gray-200">
            <img
              src="https://images.pexels.com/photos/5537874/pexels-photo-5537874.jpeg"
              alt="Weinberger Reuben"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
            />
          </div>
          <div class="p-6">
            <p class="text-accent font-bold text-sm mb-2">Story</p>
            <h2 class="font-heading font-bold text-primary text-lg mb-3 line-clamp-2">
              The Story Behind the Weinberger Reuben
            </h2>
            <p class="text-foreground/70 text-sm mb-4 line-clamp-3">
              Discover the history and inspiration behind one of our most beloved sandwiches. From a family recipe to a Junction favorite...
            </p>
            <div class="flex justify-between items-center mb-4">
              <time class="text-foreground/60 text-xs">May 1, 2024</time>
              <span class="text-foreground/60 text-xs">5 min read</span>
            </div>
            <a
              href="/blog/weinberger-reuben"
              class="inline-block px-4 py-2 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Read More
            </a>
          </div>
        </article>

        <!-- Blog Post 2 -->
        <article class="bg-card rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-border/40">
          <div class="h-48 overflow-hidden bg-gray-200">
            <img
              src="https://images.pexels.com/photos/5632621/pexels-photo-5632621.jpeg"
              alt="Local sourcing"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
            />
          </div>
          <div class="p-6">
            <p class="text-secondary font-bold text-sm mb-2">Commitment</p>
            <h2 class="font-heading font-bold text-primary text-lg mb-3 line-clamp-2">
              Why We Source Local: Our Commitment to Ennis
            </h2>
            <p class="text-foreground/70 text-sm mb-4 line-clamp-3">
              Learn about our commitment to supporting local suppliers and farmers. Fresh ingredients, local pride, community love...
            </p>
            <div class="flex justify-between items-center mb-4">
              <time class="text-foreground/60 text-xs">April 15, 2024</time>
              <span class="text-foreground/60 text-xs">4 min read</span>
            </div>
            <a
              href="#"
              class="inline-block px-4 py-2 bg-secondary text-background font-bold rounded text-sm hover:bg-secondary/90 transition-all duration-300"
            >
              Read More
            </a>
          </div>
        </article>

        <!-- Blog Post 3 -->
        <article class="bg-card rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-300 border border-border/40">
          <div class="h-48 overflow-hidden bg-gray-200">
            <img
              src="https://images.pexels.com/photos/1624487/pexels-photo-1624487.jpeg"
              alt="Muffuletta"
              class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
            />
          </div>
          <div class="p-6">
            <p class="text-accent font-bold text-sm mb-2">Feature</p>
            <h2 class="font-heading font-bold text-primary text-lg mb-3 line-clamp-2">
              Sandwich of the Month: The Muffuletta
            </h2>
            <p class="text-foreground/70 text-sm mb-4 line-clamp-3">
              A New Orleans classic lands in Downtown Ennis. Discover the flavors, the history, and why our customers can't get enough...
            </p>
            <div class="flex justify-between items-center mb-4">
              <time class="text-foreground/60 text-xs">March 30, 2024</time>
              <span class="text-foreground/60 text-xs">6 min read</span>
            </div>
            <a
              href="#"
              class="inline-block px-4 py-2 bg-primary text-accent font-bold rounded text-sm hover:bg-primary/90 transition-all duration-300"
            >
              Read More
            </a>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER SECTION -->
  <section class="bg-accent/5 py-16">
    <div class="container max-w-2xl">
      <div class="bg-card rounded-lg p-8 border border-border/40 text-center">
        <h2 class="font-heading text-2xl font-bold text-primary mb-3">
          Get Stories in Your Inbox
        </h2>
        <p class="text-foreground/70 mb-6">
          Subscribe to our newsletter for sandwich stories, specials, and updates from Limerick's Sandwich Junction.
        </p>
        <form class="flex flex-col sm:flex-row gap-3">
          <input
            type="email"
            placeholder="Enter your email"
            required
            class="flex-1 px-4 py-3 rounded border border-border/40 bg-background text-foreground placeholder-foreground/50 focus:outline-none focus:ring-2 focus:ring-primary"
          />
          <button
            type="submit"
            class="px-6 py-3 bg-primary text-accent font-bold rounded hover:bg-primary/90 transition-all duration-300 whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
        <p class="text-foreground/50 text-xs mt-4">
          We'll never spam you. Unsubscribe anytime.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
