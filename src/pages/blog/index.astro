---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogCard from "@/components/blog/BlogCard.astro";
import { getPosts } from "@/lib/wordpress";

// Fetch blog posts at build time (use per_page=100 to ensure consistent WordPress API results)
const allPosts = await getPosts(1, 100);
// Display first 12 posts on this page
const posts = allPosts.slice(0, 12);

// Get unique categories from posts
const categories = new Set<string>();
allPosts.forEach(post => {
  post.categories.forEach(cat => {
    categories.add(cat.slug);
  });
});

const categoryMetadata: Record<string, string> = {
  "web-design": "Web Design",
  "web-speed": "Web Speed",
  "seo-technical": "Technical SEO",
  "websites-for-sale": "Websites for Sale",
  "case-studies": "Case Studies",
  "news-trends": "News & Trends",
  "about-astro": "About Astro",
  "case-study": "Case Studies",
  "how-to": "How To",
  "human-designers": "Human Designers"
};
---

<BaseLayout
  title="Blog | Astrobot.design"
  description="Explore our latest insights, tips, and news about fast website development, AI technology, and the Astro framework."
>
  <!-- Breadcrumb Navigation -->
  <nav class="py-4 border-b border-border/40">
    <div class="container text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground transition-colors">Home</a>
      <span class="mx-2">/</span>
      <a href="/blog" class="text-foreground font-medium">Blog</a>
    </div>
  </nav>

  <section class="py-16 md:py-24">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-heading font-bold tracking-tight mb-6">
          Our Blog
        </h1>
        <p class="text-xl text-muted-foreground mb-8">
          Insights and tips for building faster, better websites
        </p>

        <!-- Category Navigation -->
        <div class="flex flex-wrap gap-2 justify-center mb-8">
          <a href="/blog" class="px-4 py-2 rounded-full bg-primary text-primary-foreground text-sm font-medium hover:bg-primary/90 transition-colors">
            All Posts
          </a>
          {Array.from(categories).map(slug => (
            <a
              href={`/blog/category/${slug}`}
              class="px-4 py-2 rounded-full bg-muted text-muted-foreground text-sm font-medium hover:bg-muted/80 hover:text-foreground transition-colors"
            >
              {categoryMetadata[slug] || slug.replace(/-/g, ' ')}
            </a>
          ))}
        </div>
      </div>
      
      {posts.length === 0 ? (
        <div class="text-center py-12 border border-primary/10 rounded-lg bg-secondary/20">
          <p class="text-lg text-muted-foreground">No blog posts found.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map(post => (
            <BlogCard post={post} />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
