---
import { MobileMenu } from "@/components/MobileMenu";
---

<header
  class="bg-primary sticky top-0 z-50 w-full border-b-4 border-accent/60 shadow-md"
>
  <div
    class="container flex h-20 items-center justify-between space-x-4"
  >
    <!-- Logo and Name -->
    <a href="/" class="flex items-center space-x-3 group">
      <img 
        src="https://static.wixstatic.com/media/4a6e31_7f7b5b2a33d44e4ab097dab20c64cf25~mv2.png" 
        alt="Limerick's Sandwich Junction" 
        class="h-12 w-auto group-hover:scale-105 transition-transform duration-300"
      />
      <div class="hidden sm:block">
        <div class="font-heading font-bold text-lg tracking-wide text-accent group-hover:text-background transition-colors duration-300">
          LIMERICK'S
        </div>
        <div class="font-body text-xs tracking-widest text-background/90">
          Sandwich Junction
        </div>
      </div>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center space-x-8 flex-1 justify-center">
      <a
        href="/"
        class="text-sm font-medium text-background hover:text-accent transition-colors duration-300"
      >
        Home
      </a>
      <a
        href="/menu"
        class="text-sm font-medium text-background hover:text-accent transition-colors duration-300"
      >
        Menu
      </a>
      <a
        href="/vegetarian"
        class="text-sm font-medium text-background hover:text-accent transition-colors duration-300"
      >
        Vegetarian
      </a>
      <a
        href="/catering"
        class="text-sm font-medium text-background hover:text-accent transition-colors duration-300"
      >
        Catering
      </a>
      <a
        href="/blog"
        class="text-sm font-medium text-background hover:text-accent transition-colors duration-300"
      >
        Blog
      </a>
    </nav>

    <!-- Right side: Phone and Order Button -->
    <div class="flex items-center space-x-4">
      <div class="hidden lg:block">
        <a 
          href="tel:+19034051995" 
          class="text-sm font-medium text-background hover:text-accent transition-colors"
        >
          (903) 405-1995
        </a>
      </div>
      <a
        href="https://limerickssandwichjunction.smartonlineorder.com/"
        target="_blank"
        rel="noopener noreferrer"
        class="hidden sm:inline-flex px-4 py-2 bg-accent text-primary font-bold rounded hover:bg-accent/90 transition-all duration-300 text-sm"
      >
        Order Online
      </a>
      <MobileMenu client:load links={[
        { href: "/", label: "Home" },
        { href: "/menu", label: "Menu" },
        { href: "/vegetarian", label: "Vegetarian" },
        { href: "/catering", label: "Catering" },
        { href: "/blog", label: "Blog" },
        { href: "tel:+19034051995", label: "Call (903) 405-1995" },
        { href: "https://limerickssandwichjunction.smartonlineorder.com/", label: "Order Online", external: true }
      ]} />
    </div>
  </div>
</header>
