---
import { buttonVariants } from "@/components/ui/button";
import { Rocket } from "lucide-react";
import { MobileMenu } from "@/components/MobileMenu";
---

<header
  class="bg-background/80 supports-[backdrop-filter]:bg-background/60 sticky top-0 z-50 w-full border-b border-border/40 backdrop-blur transition-all duration-300"
>
  <div
    class="container flex h-16 items-center space-x-4 sm:justify-between sm:space-x-0"
  >
    <div class="flex gap-6 md:gap-10">
      <a href="/" class="flex items-center space-x-2 group">
        <div class="bg-primary/10 p-1.5 rounded-md border border-primary/20 group-hover:border-primary/50 transition-all duration-300">
          <Rocket className="h-5 w-5 text-primary group-hover:text-primary group-hover:animate-pulse" />
        </div>
        <span class="inline-block font-heading font-bold tracking-widest text-foreground/90 group-hover:text-primary transition-colors duration-300">ASTROBOT.DESIGN</span>
      </a>
    </div>
    <div class="flex flex-1 items-center justify-end space-x-4">
      <nav class="hidden md:flex items-center space-x-3">
        <div class="relative group">
          <button class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors flex items-center gap-1">
            Services
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
            </svg>
          </button>
          <div class="absolute left-0 mt-0 w-48 bg-background border border-border rounded-md shadow-lg opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2">
            <a href="/services/web-design" class="block px-4 py-2 text-sm text-muted-foreground hover:text-foreground hover:bg-muted transition-colors">
              Web Design
            </a>
          </div>
        </div>
        <a
          href="/blog"
          class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
        >
          Blog
        </a>
        <a
          href="/headless-cms"
          class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
        >
          Headless CMS
        </a>
        <a
          href="/websites-for-sale"
          class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
        >
          Websites for Sale
        </a>
        <a
          href="/pricing"
          class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
        >
          Pricing
        </a>
      </nav>
      <MobileMenu client:load links={[
        { href: "/services/web-design", label: "Web Design" },
        { href: "/blog", label: "Blog" },
        { href: "/headless-cms", label: "Headless CMS" },
        { href: "/websites-for-sale", label: "Websites for Sale" },
        { href: "/pricing", label: "Pricing" }
      ]} />
    </div>
  </div>
</header>
