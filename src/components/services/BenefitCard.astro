---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<div class="p-6 bg-background rounded-lg border border-border hover:border-primary/50 transition-colors">
  <h3 class="font-bold text-lg mb-3">{title}</h3>
  <p class="text-muted-foreground">{description}</p>
</div>
