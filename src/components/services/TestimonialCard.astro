---
interface Props {
  quote: string;
  author: string;
  title: string;
  company: string;
}

const { quote, author, title, company } = Astro.props;
---

<div class="p-8 bg-muted/30 rounded-lg border border-border">
  <div class="flex gap-1 mb-4">
    {[...Array(5)].map(() => (
      <span class="text-yellow-400">★</span>
    ))}
  </div>
  <p class="text-muted-foreground mb-6 italic">"{quote}"</p>
  <div>
    <p class="font-bold text-foreground">{author}</p>
    <p class="text-sm text-muted-foreground">{title} at {company}</p>
  </div>
</div>
