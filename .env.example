# WordPress API Configuration
# The base URL of your WordPress REST API endpoint
# Used for both local dev and GitHub Actions builds
# All sites use the same central WordPress instance
# Default: https://blog.nxtmt.ventures/wp-json/wp/v2
WORDPRESS_API_URL=https://blog.nxtmt.ventures/wp-json/wp/v2

# WordPress Category Slug
# Only posts from this category will be displayed on the blog
#
# ⚠️ IMPORTANT: Environment Variable Setup
# - LOCAL DEV: This .env file is used when running 'pnpm build' locally
# - GITHUB ACTIONS: The GitHub Actions workflow reads from a repository secret instead
#   (Set via Settings → Secrets and variables → Actions → WORDPRESS_CATEGORY_SLUG)
#
# For local development, use the category slug of YOUR site:
WORDPRESS_CATEGORY_SLUG=astrobot-design
